# docker-compose.prod.yml 용 — 복사해서 .env로 저장하고 값 채움 (.env는 커밋 금지)
#   cp .env.example .env

# Postgres(JPA+pgvector) 비밀번호 — 필수
DB_PASSWORD=change-me-strong-password

# 인증: 데모는 false(UI 동작), 운영은 true
SECURITY_ENABLED=false
# apikey-filter(A) | spring-apikey(B) | jwt(C)
SECURITY_MODE=apikey-filter

# 운영 모니터링 — Grafana admin 비번 (기본 admin 금지)
GRAFANA_PASSWORD=change-me-grafana

# 운영 인증 키 주입 예시 (prod는 api-keys 비어있음 → 미주입이면 전부 401)
#   SECURITY_APIKEYS_<KEYNAME>=ns1,ns2   또는 SPRING_APPLICATION_JSON 으로 security.api-keys 주입
